# Lethe — example configuration
#
# Copy to .env (or to ~/.lethe/config/.env which is auto-loaded if
# LETHE_HOME is the default) and edit. Run `lethe init` for the full
# interactive wizard, or `lethe login <openai|anthropic|openrouter>`
# to add/swap one provider without re-running setup.
#
# Comment-out a line to fall back to its built-in default.

# =============================================================================
# LLM provider — at least one auth method + LLM_MODEL is required
# =============================================================================

# Choose ONE of these auth methods:
#   OpenRouter (single key, every major model). `lethe login openrouter`.
OPENROUTER_API_KEY=

#   Anthropic API key (pay-per-token) — get one at
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

#   Anthropic Claude Pro/Max subscription via OAuth — set up with
#   `lethe login anthropic` (writes ~/.lethe/credentials/anthropic_oauth_tokens.json).
#   Override the token file path with LETHE_ANTHROPIC_OAUTH_TOKENS, or
#   paste a raw token here:
# ANTHROPIC_AUTH_TOKEN=

#   OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

#   OpenCode Go API key — budget-friendly open models ($5–$10/month).
#   Get one at https://opencode.ai/zen/go
OPENCODE_GO_API_KEY=

#   OpenAI ChatGPT Plus/Pro subscription via OAuth — set up with
#   `lethe login openai` (writes ~/.lethe/credentials/openai_oauth_tokens.json).
#   Override the token file path with LETHE_OPENAI_OAUTH_TOKENS, or
#   paste a raw token here:
# OPENAI_AUTH_TOKEN=

# Main model the cortex uses for user-facing turns.
# Examples:
#   openrouter/moonshotai/kimi-k2.6
#   claude-opus-4-7
#   gpt-5.5
LLM_MODEL=

# Auxiliary model — used for cheap background calls (summarization,
# heartbeat, curator). Leave empty to reuse LLM_MODEL.
LLM_MODEL_AUX=

# Tool/reasoning model — optional. When set (and different from LLM_MODEL), a
# turn starts on LLM_MODEL and transparently switches to this model the moment
# the assistant calls a tool, staying on it for the rest of the tool chain
# (including the post-chain reply). The next turn starts on LLM_MODEL again.
# Lets a cheap model drive normal conversation while a stronger reasoner runs
# tool chains. Leave empty to disable mid-turn switching.
# Example: LLM_MODEL=openrouter/google/gemma-4-31b-it with
#          LLM_MODEL_TOOL=openrouter/deepseek/deepseek-v4-pro
LLM_MODEL_TOOL=

# Explicit provider override (anthropic | openai | openrouter | opencode-go). Usually
# inferred from LLM_MODEL prefix; the subscription OAuth paths need it
# set so the router picks the OAuth client instead of looking for an
# API key. `lethe login` sets this for you.
LLM_PROVIDER=

# Custom base URL for OpenAI-compatible servers (Ollama, vLLM, llama.cpp).
LLM_API_BASE=

# Model context window in tokens. Auto-detected for catalog models; this
# is the fallback for unrecognised model ids.
LLM_CONTEXT_LIMIT=100000

# Per-request max output tokens. Also drives the prompt-cache reserve.
LLM_MAX_OUTPUT=8000

# =============================================================================
# Telegram bot (optional — only when running `lethe telegram`)
# =============================================================================

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user ids allowed to message the bot.
TELEGRAM_ALLOWED_USER_IDS=

# Transcribe incoming voice notes to text.
TELEGRAM_TRANSCRIPTION_ENABLED=true

# Transcription provider: auto | openai | openrouter | mistral | local
# `auto` prefers an OpenRouter/OpenAI key, then a Mistral key, then local Whisper.
# `mistral` uses Voxtral (voxtral-mini-latest) via MISTRAL_API_KEY below — strong
# multilingual (DE/FR/IT) speech-to-text; cheaper than whisper-1 and not EN-centric.
TRANSCRIPTION_PROVIDER=
TRANSCRIPTION_MODEL=
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_LOCAL_COMMAND=whisper

# Mistral API key — only used for `mistral` transcription (Voxtral STT), not the
# chat LLM. Get one at https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# =============================================================================
# HTTP / SSE API server (optional — only when running `lethe api`)
# =============================================================================

LETHE_API_HOST=127.0.0.1
LETHE_API_PORT=1373

# Bearer token required on every API request. Empty disables auth (dev only).
LETHE_API_TOKEN=

# =============================================================================
# Web search tools (optional)
# =============================================================================

# Exa API key. Without it, web_search / fetch_webpage return errors but
# the app keeps running.
EXA_API_KEY=

# =============================================================================
# Background subsystems
# =============================================================================

# Spawn the actor runtime (cortex + subagents). Disable for single-turn CLI use.
ACTORS_ENABLED=true

# Hippocampus recall (semantic search over past notes/conversations/archival).
HIPPOCAMPUS_ENABLED=true

# Curator — periodic memory harvest into archival storage.
CURATOR_ENABLED=true

# Heartbeat — proactive background nudges.
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL=3600

# Telegram message debounce (seconds). Multi-line bursts merge into one turn.
DEBOUNCE_SECONDS=5.0

# Proactive notification rate limits.
PROACTIVE_MAX_PER_DAY=4
PROACTIVE_COOLDOWN_MINUTES=60

# =============================================================================
# Embeddings (semantic memory)
# =============================================================================

# fastembed model id. Default is a small nomic-embed model (~150MB download).
# LETHE_EMBEDDING_MODEL=

# Disable semantic search entirely (notes/archival fall back to keyword search).
# LETHE_SEMANTIC_SEARCH_ENABLED=true

# =============================================================================
# Paths (rarely overridden)
# =============================================================================

# Root of every Lethe-managed directory. Defaults to ~/.lethe.
# LETHE_HOME=

# Individual overrides — by default these live under LETHE_HOME.
# WORKSPACE_DIR=
# MEMORY_DIR=
# DB_PATH=
# CREDENTIALS_DIR=
# CACHE_DIR=
# LOGS_DIR=
# NOTES_DIR=
# LETHE_CONFIG_DIR=

# =============================================================================
# Runtime
# =============================================================================

# Default subcommand when `lethe` is invoked bare: cli | api | telegram
LETHE_MODE=cli

# Logical name used in logs and prompts.
LETHE_AGENT_NAME=lethe

# OAuth concurrency limit shared by the Anthropic and OpenAI
# subscription paths (per-process semaphore for outbound calls).
# LETHE_OAUTH_MAX_CONCURRENCY=4

# =============================================================================
# Debugging
# =============================================================================

# Dump every LLM request/response to disk for inspection.
# LLM_DEBUG=true
# LLM_DEBUG_DIR=
