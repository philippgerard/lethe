#!/usr/bin/env bash
#
# Build a GitHub release archive for the lethe-migrate binary on the
# current host. Sister script to scripts/package-release.

set -euo pipefail

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
DIST_DIR="${LETHE_DIST_DIR:-$ROOT_DIR/dist}"
BIN_PATH="${LETHE_MIGRATE_BIN:-$ROOT_DIR/migrator/target/release/lethe-migrate}"

detect_target() {
    local os arch
    os="$(uname -s)"
    arch="$(uname -m)"
    case "$os:$arch" in
        Linux:x86_64|Linux:amd64) echo "x86_64-unknown-linux-gnu" ;;
        Linux:aarch64|Linux:arm64) echo "aarch64-unknown-linux-gnu" ;;
        Darwin:x86_64|Darwin:amd64) echo "x86_64-apple-darwin" ;;
        Darwin:aarch64|Darwin:arm64) echo "aarch64-apple-darwin" ;;
        *) return 1 ;;
    esac
}

TARGET="${LETHE_RELEASE_TARGET:-$(detect_target)}"
PACKAGE_NAME="lethe-migrate-$TARGET"
ARCHIVE="$DIST_DIR/$PACKAGE_NAME.tar.gz"
WORK_DIR="$(mktemp -d)"

cleanup() {
    rm -rf "$WORK_DIR"
}
trap cleanup EXIT

cd "$ROOT_DIR"

if [ ! -x "$BIN_PATH" ]; then
    cargo build --release --manifest-path migrator/Cargo.toml
fi

mkdir -p "$DIST_DIR" "$WORK_DIR/$PACKAGE_NAME"
cp "$BIN_PATH" "$WORK_DIR/$PACKAGE_NAME/lethe-migrate"
cp migrator/README.md "$WORK_DIR/$PACKAGE_NAME/README.md"
cp MIGRATION-SPEC.md "$WORK_DIR/$PACKAGE_NAME/"
if [ -f LICENSE ]; then
    cp LICENSE "$WORK_DIR/$PACKAGE_NAME/"
fi

tar -C "$WORK_DIR" -czf "$ARCHIVE" "$PACKAGE_NAME"

if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$ARCHIVE" > "$ARCHIVE.sha256"
else
    shasum -a 256 "$ARCHIVE" > "$ARCHIVE.sha256"
fi

printf '%s\n' "$ARCHIVE"
